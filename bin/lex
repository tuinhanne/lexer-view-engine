#!/usr/bin/env php
<?php

declare(strict_types=1);

// Locate the Composer autoloader, supporting both standalone and package usage.
$autoloaders = [
    __DIR__ . '/../vendor/autoload.php',   // standalone: project root/vendor
    __DIR__ . '/../../../autoload.php',    // installed as a package: vendor/wik/lexer
];

$loaded = false;

foreach ($autoloaders as $file) {
    if (file_exists($file)) {
        require $file;
        $loaded = true;
        break;
    }
}

if (!$loaded) {
    fwrite(STDERR, "Composer autoloader not found.\nRun: composer install\n");
    exit(1);
}

use Wik\Lexer\Console\Application;

$app = new Application();

exit($app->run());
