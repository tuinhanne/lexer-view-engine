{
    "name": "wik/lexer",
    "description": "A modern AST-based view engine for PHP 8.1+ with custom syntax, layout system, and component support",
    "keywords": ["Lexer View", "template", "view", "engine", "ast", "components"],
    "license": "MIT",
    "authors": [
        {
            "name": "Nguyen Thanh Nhan",
            "role": "Publisher"
        }
    ],
    "require": {
        "php": "^8.1",
        "phpunit/phpunit": "^10.0 || ^11.0",
        "psr/http-server-middleware": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "Wik\\Lexer\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Wik\\Lexer\\Tests\\": "tests/"
        }
    },
    "bin": [
        "bin/lex"
    ],
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true
    }
}
